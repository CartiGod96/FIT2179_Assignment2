{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "A high-fidelity spatial shot blueprint with structural grid partitioning.",
  "width": 800,
  "height": 430,
  "layer": [
    {
      "data": { "values": [{}] },
      "mark": { "type": "image", "url": "images/fiba_court_flat.png", "width": 800, "height": 430 },
      "encoding": {
        "x": {"datum": 50, "scale": {"domain": [0, 100]}, "axis": null},
        "y": {"datum": 50, "scale": {"domain": [0, 100]}, "axis": null}
      }
    },
    {
      "data": { "url": "data/nbl_shot_coordinates.csv" },
      "params": [
        {
          "name": "density_chart_team_dropdown",
          "select": { "type": "point", "fields": ["Team"] },
          "bind": {
            "input": "select",
            "options": [
              null, "Adelaide 36ers", "Brisbane Bullets", "Cairns Taipans", "Illawarra Hawks",
              "Melbourne United", "New Zealand Breakers", "Perth Wildcats",
              "South East Melbourne Phoenix", "Sydney Kings", "Tasmania JackJumpers"
            ],
            "labels": [
              "League-Wide Density (Show All)", "Adelaide 36ers", "Brisbane Bullets", "Cairns Taipans", "Illawarra Hawks",
              "Melbourne United", "New Zealand Breakers", "Perth Wildcats",
              "South East Melbourne Phoenix", "Sydney Kings", "Tasmania JackJumpers"
            ],
            "name": "Isolate Density Profile: "
          }
        }
      ],
      "transform": [
        { "filter": {"param": "density_chart_team_dropdown"} },
        {
          "calculate": "datum.Shot_Outcome == 'Make' ? 1 : 0",
          "as": "shot_made_numeric"
        }
      ],
      "mark": {
        "type": "rect",
        "filled": false,
        "opacity": 0.9,
        "strokeWidth": 3.5
      },
      "encoding": {
        "x": {
          "field": "X",
          "type": "quantitative",
          "bin": {"step": 15},
          "scale": {"domain": [0, 100]},
          "axis": null
        },
        "y": {
          "field": "Y",
          "type": "quantitative",
          "bin": {"step": 20},
          "scale": {"domain": [0, 100]},
          "axis": null
        },
        "stroke": {
          "aggregate": "mean",
          "field": "shot_made_numeric",
          "type": "quantitative",
          "title": "Zone FG%",
          "scale": {
            "scheme": "redyellowblue",
            "reverse": true,
            "domain": [0.25, 0.60]
          },
          "legend": {
            "format": ".0%",
            "orient": "right",
            "titlePadding": 10
          }
        },
        "color": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Attempts Volume",
          "scale": {"scheme": "greys", "range": ["#e0e0e0", "#212121"]},
          "legend": {
            "orient": "right",
            "titlePadding": 10
          }
        },
        "tooltip": [
          {"aggregate": "count", "type": "quantitative", "title": "Total Visualized Attempts"},
          {"aggregate": "mean", "field": "shot_made_numeric", "type": "quantitative", "title": "Calculated Zone FG%", "format": ".1%"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent", "background": "transparent"},
    "scale": {"invalid": {"color": null}}
  }
}