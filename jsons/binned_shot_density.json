{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Clean, volume-filtered court grid with a sequential blue efficiency scale.",
  "width": 800,
  "height": 430,
  "layer": [
    {
      "data": { "values": [{}] },
      "mark": { "type": "image", "url": "images/fiba_court_flat.png", "width": 800, "height": 430 },
      "encoding": {
        "x": {"datum": 50, "scale": {"domain": [0, 100]}, "axis": null},
        "y": {"datum": 50, "scale": {"domain": [0, 100]}, "axis": null}
      }
    },
    {
      "data": { "url": "data/nbl_shot_coordinates.csv" },
      "params": [
        {
          "name": "density_chart_team_dropdown",
          "select": { "type": "point", "fields": ["Team"] },
          "bind": {
            "input": "select",
            "options": [
              null, "Adelaide 36ers", "Brisbane Bullets", "Cairns Taipans", "Illawarra Hawks",
              "Melbourne United", "New Zealand Breakers", "Perth Wildcats",
              "South East Melbourne Phoenix", "Sydney Kings", "Tasmania JackJumpers"
            ],
            "labels": [
              "League-Wide Density (Show All)", "Adelaide 36ers", "Brisbane Bullets", "Cairns Taipans", "Illawarra Hawks",
              "Melbourne United", "New Zealand Breakers", "Perth Wildcats",
              "South East Melbourne Phoenix", "Sydney Kings", "Tasmania JackJumpers"
            ],
            "name": "Isolate Density Profile: "
          }
        }
      ],
      "transform": [
        { "filter": {"param": "density_chart_team_dropdown"} },
        { "filter": "datum.X >= 2 && datum.X <= 98 && datum.Y >= 2 && datum.Y <= 98" },
        {
          "calculate": "datum.Shot_Outcome == 'Make' ? 1 : 0",
          "as": "shot_made_numeric"
        },
        {
          "bin": {"step": 15}, "field": "X", "as": "binned_x"
        },
        {
          "bin": {"step": 20}, "field": "Y", "as": "binned_y"
        },
        {
          "joinaggregate": [
            {"op": "count", "as": "zone_shot_count"},
            {"op": "mean", "field": "shot_made_numeric", "as": "zone_fg_percentage"}
          ],
          "groupby": ["binned_x", "binned_y"]
        },
        { "filter": "datum.zone_shot_count >= 15" }
      ],
      "mark": {
        "type": "rect",
        "filled": true,
        "opacity": 0.65,
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "binned_x",
          "type": "quantitative",
          "scale": {"domain": [0, 100]},
          "axis": null
        },
        "y": {
          "field": "binned_y",
          "type": "quantitative",
          "scale": {"domain": [0, 100]},
          "axis": null
        },
        "color": {
          "field": "zone_fg_percentage",
          "type": "quantitative",
          "title": "Zone FG%",
          "scale": {
            "scheme": "blues",
            "domain": [0.30, 0.55]
          },
          "legend": {
            "format": ".0%",
            "orient": "right",
            "titlePadding": 10
          }
        },
        "tooltip": [
          {"field": "zone_shot_count", "type": "quantitative", "title": "Attempts in Zone"},
          {"field": "zone_fg_percentage", "type": "quantitative", "title": "Zone FG%", "format": ".1%"}
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent", "background": "transparent"},
    "scale": {"invalid": {"color": null}}
  }
}