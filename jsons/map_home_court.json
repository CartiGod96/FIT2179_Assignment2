{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "NBL Stadium Map Projection",
  "width": 600,
  "height": 450,
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {"type": "json"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eaeaea",
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      }
    },
    {
      "data": {
        "url": "data/nbl_stadium_coords.csv"
      },
      "mark": {
        "type": "circle",
        "opacity": 0.85,
        "color": "#e67e22"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "size": {
          "field": "Capacity",
          "type": "quantitative",
          "title": "Stadium Capacity",
          "scale": {"domain": [4000, 20000], "range": [100, 800]}
        },
        "tooltip": [
          {"field": "Team", "type": "nominal", "title": "Franchise"},
          {"field": "Stadium", "type": "nominal", "title": "Home Court"},
          {"field": "Capacity", "type": "quantitative", "title": "Capacity", "format": ","}
        ]
      }
    }
  ]
}