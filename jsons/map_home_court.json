{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "NBL Stadium Map Projection with Unique Legend Selection",
  "width": "container",
  "height": 450,
  "projection": {
    "type": "mercator"
  },
  "params": [
    {
      "name": "map_legend_select",
      "select": {"type": "point", "fields": ["Team"]},
      "bind": "legend"
    }
  ],
  "layer": [
    {
      "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
        "format": {"type": "json"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#eaeaea",
        "stroke": "#ffffff",
        "strokeWidth": 1.5
      }
    },
    {
      "data": {
        "url": "data/nbl_stadium_coords.csv"
      },
      "mark": {
        "type": "circle",
        "cursor": "pointer"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "size": {
          "field": "Capacity",
          "type": "quantitative",
          "title": "Stadium Capacity",
          "scale": {"domain": [4000, 20000], "range": [80, 600]}
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Franchise",
          "scale": {"scheme": "tableau10"}
        },
        "opacity": {
          "condition": {"param": "map_legend_select", "value": 0.9},
          "value": 0.15
        },
        "tooltip": [
          {"field": "Stadium", "type": "nominal"},
          {"field": "Team", "type": "nominal", "title": "Home Franchise"},
          {"field": "Capacity", "type": "quantitative", "title": "Seating Capacity", "format": ","}
        ]
      }
    }
  ]
}