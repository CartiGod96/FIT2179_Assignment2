{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Parallel Coordinates Utility Profiles via Fixed League Percentile Rankings (Normalized Per-40 / Efficiency Stats)",
  "data": {
    "url": "data/nbl-player-stats.csv",
    "format": {
      "type": "csv",
      "parse": {
        "Minutes_A": "number",
        "Matches": "number",
        "Points_40": "number",
        "Supercoach_40": "number",
        "ARR_40": "number",
        "FIC_40": "number",
        "PIE": "number"
      }
    }
  },
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "params": [
    {
      "name": "pcp_team_filter",
      "select": {"type": "point", "fields": ["Team"]},
      "bind": {
        "input": "select",
        "options": [
          null,
          "Adelaide",
          "Brisbane",
          "Cairns",
          "Illawarra",
          "Melbourne",
          "New Zealand",
          "Perth",
          "South East Melbourne",
          "Sydney",
          "Tasmania"
        ],
        "labels": [
          "Show All Franchises",
          "Adelaide 36ers",
          "Brisbane Bullets",
          "Cairns Taipans",
          "Illawarra Hawks",
          "Melbourne United",
          "New Zealand Breakers",
          "Perth Wildcats",
          "South East Melbourne Phoenix",
          "Sydney Kings",
          "Tasmania JackJumpers"
        ],
        "name": "Isolate Franchise Roster: "
      }
    },
    {
      "name": "pcp_profile_hover",
      "select": {"type": "point", "on": "mouseover", "clear": "mouseout", "fields": ["Player"]}
    }
  ],
  "transform": [
    {
      "filter": "datum.Minutes_A > 12 && datum.Matches > 5"
    },
    {
      "window": [{"op": "rank", "as": "rank_pts40"}],
      "sort": [{"field": "Points_40", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_sc40"}],
      "sort": [{"field": "Supercoach_40", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_arr40"}],
      "sort": [{"field": "ARR_40", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_fic40"}],
      "sort": [{"field": "FIC_40", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_pie"}],
      "sort": [{"field": "PIE", "order": "ascending"}]
    },
    {
      "window": [{"op": "count", "as": "total_players"}],
      "frame": [null, null]
    },
    {
      "calculate": "(datum.rank_pts40 - 1) / (datum.total_players - 1)",
      "as": "Pts/40"
    },
    {
      "calculate": "(datum.rank_sc40 - 1) / (datum.total_players - 1)",
      "as": "Supercoach 40"
    },
    {
      "calculate": "(datum.rank_arr40 - 1) / (datum.total_players - 1)",
      "as": "ARR 40"
    },
    {
      "calculate": "(datum.rank_fic40 - 1) / (datum.total_players - 1)",
      "as": "FIC 40"
    },
    {
      "calculate": "(datum.rank_pie - 1) / (datum.total_players - 1)",
      "as": "Impact (PIE)"
    },
    {
      "filter": {"param": "pcp_team_filter"}
    },
    {
      "fold": ["Pts/40", "Supercoach 40", "ARR 40", "FIC 40", "Impact (PIE)"],
      "as": ["Metric", "Percentile_Value"]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line", 
        "interpolate": "linear",
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "Metric",
          "type": "nominal",
          "title": "Normalised Per-40 / Efficiency Metric Axes",
          "sort": ["Pts/40", "Supercoach 40", "ARR 40", "FIC 40", "Impact (PIE)"],
          "axis": {"labelAngle": 0, "grid": true}
        },
        "y": {
          "field": "Percentile_Value",
          "type": "quantitative",
          "title": "League Percentile Rank (0 to 1.0)",
          "axis": {"format": ".0%"}
        },
        "strokeWidth": {
          "condition": {"param": "pcp_profile_hover", "value": 4.5},
          "value": 1.5
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Team Squad",
          "scale": {"scheme": "tableau10"}
        },
        "opacity": {
          "condition": {"param": "pcp_profile_hover", "value": 1.0},
          "value": 0.2
        },
        "detail": {"field": "Player"},
        "tooltip": [
          {"field": "Player", "type": "nominal", "title": "Player"},
          {"field": "Team", "type": "nominal", "title": "Team"},
          {"field": "Minutes_A", "type": "quantitative", "title": "Mins/G"},
          {"field": "Points_40", "type": "quantitative", "title": "Pts/40"},
          {"field": "Supercoach_40", "type": "quantitative", "title": "Supercoach 40"},
          {"field": "ARR_40", "type": "quantitative", "title": "ARR 40"},
          {"field": "FIC_40", "type": "quantitative", "title": "FIC 40"},
          {"field": "PIE", "type": "quantitative", "title": "PIE Metric"}
        ]
      }
    }
  ],
  "config": {
    "axis": {"titleFontWeight": "bold", "labelFontSize": 11}
  }
}