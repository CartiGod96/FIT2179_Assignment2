{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Parallel Coordinates Utility Profiles via Fixed League Percentile Rankings",
  "data": {
    "url": "data/nbl-player-stats.csv",
    "format": {
      "type": "csv",
      "parse": {
        "Minutes_A": "number",
        "Points_A": "number",
        "PIE": "number",
        "ARR": "number",
        "Matches": "number"
      }
    }
  },
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "params": [
    {
      "name": "pcp_team_filter",
      "select": {"type": "point", "fields": ["Team"]},
      "bind": {
        "input": "select",
        "options": [
          null,
          "Adelaide",
          "Brisbane",
          "Cairns",
          "Illawarra",
          "Melbourne",
          "New Zealand",
          "Perth",
          "South East Melbourne",
          "Sydney",
          "Tasmania"
        ],
        "labels": [
          "Show All Franchises",
          "Adelaide 36ers",
          "Brisbane Bullets",
          "Cairns Taipans",
          "Illawarra Hawks",
          "Melbourne United",
          "New Zealand Breakers",
          "Perth Wildcats",
          "South East Melbourne Phoenix",
          "Sydney Kings",
          "Tasmania JackJumpers"
        ],
        "name": "Isolate Franchise Roster: "
      }
    },
    {
      "name": "pcp_profile_hover",
      "select": {"type": "point", "on": "mouseover", "clear": "mouseout", "fields": ["Player"]}
    }
  ],
  "transform": [
    {
      "filter": "datum.Minutes_A > 12 && datum.Matches > 5"
    },
    {
      "window": [{"op": "rank", "as": "rank_mins"}],
      "sort": [{"field": "Minutes_A", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_pts"}],
      "sort": [{"field": "Points_A", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_pie"}],
      "sort": [{"field": "PIE", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_arr"}],
      "sort": [{"field": "ARR", "order": "ascending"}]
    },
    {
      "window": [{"op": "count", "as": "total_players"}],
      "frame": [null, null]
    },
    {
      "calculate": "(datum.rank_mins - 1) / (datum.total_players - 1)",
      "as": "Mins/G"
    },
    {
      "calculate": "(datum.rank_pts - 1) / (datum.total_players - 1)",
      "as": "Pts/G"
    },
    {
      "calculate": "(datum.rank_pie - 1) / (datum.total_players - 1)",
      "as": "Impact (PIE)"
    },
    {
      "calculate": "(datum.rank_arr - 1) / (datum.total_players - 1)",
      "as": "Rim Def (ARR)"
    },
    {
      "filter": {"param": "pcp_team_filter"}
    },
    {
      "fold": ["Mins/G", "Pts/G", "Impact (PIE)", "Rim Def (ARR)"],
      "as": ["Metric", "Percentile_Value"]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "line", 
        "interpolate": "linear",
        "cursor": "pointer"
      },
      "encoding": {
        "x": {
          "field": "Metric",
          "type": "nominal",
          "title": "Roster Metric Axes",
          "sort": ["Mins/G", "Pts/G", "Impact (PIE)", "Rim Def (ARR)"],
          "axis": {"labelAngle": 0, "grid": true}
        },
        "y": {
          "field": "Percentile_Value",
          "type": "quantitative",
          "title": "League Percentile Rank (0 to 1.0)",
          "axis": {"format": ".0%"}
        },
        "strokeWidth": {
          "condition": {"param": "pcp_profile_hover", "value": 4.5},
          "value": 1.5
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Team Squad",
          "scale": {"scheme": "tableau10"}
        },
        "opacity": {
          "condition": {"param": "pcp_profile_hover", "value": 1.0},
          "value": 0.2
        },
        "detail": {"field": "Player"},
        "tooltip": [
          {"field": "Player", "type": "nominal", "title": "Player"},
          {"field": "Team", "type": "nominal", "title": "Team"},
          {"field": "Minutes_A", "type": "quantitative", "title": "Mins/G"},
          {"field": "Points_A", "type": "quantitative", "title": "Pts/G"},
          {"field": "PIE", "type": "quantitative", "title": "PIE Metric"},
          {"field": "ARR", "type": "quantitative", "title": "ARR Index"}
        ]
      }
    }
  ],
  "config": {
    "axis": {"titleFontWeight": "bold", "labelFontSize": 11}
  }
}