{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Parallel Coordinates Utility Profiles via Fixed League Percentile Rankings",
  "data": {
    "url": "data/nbl-player-stats.csv",
    "format": {
      "type": "csv",
      "parse": {
        "Minutes_A": "number",
        "Points_A": "number",
        "PIE": "number",
        "ARR": "number",
        "Matches": "number"
      }
    }
  },
  "width": "container",
  "height": 340,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "params": [
    {
      "name": "archetype_team_filter",
      "select": {"type": "point", "fields": ["Team"]},
      "bind": {
        "input": "select",
        "options": [
          null,
          "Adelaide",
          "Brisbane",
          "Cairns",
          "Illawarra",
          "Melbourne",
          "New Zealand",
          "Perth",
          "South East Melbourne",
          "Sydney",
          "Tasmania"
        ],
        "labels": [
          "Show All Franchises",
          "Adelaide 36ers",
          "Brisbane Bullets",
          "Cairns Taipans",
          "Illawarra Hawks",
          "Melbourne United",
          "New Zealand Breakers",
          "Perth Wildcats",
          "South East Melbourne Phoenix",
          "Sydney Kings",
          "Tasmania JackJumpers"
        ],
        "name": "Filter Team Archetype: "
      }
    }
  ],
  "transform": [
    {
      "window": [{"op": "rank", "as": "rank_mins"}],
      "sort": [{"field": "Minutes_A", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_pts"}],
      "sort": [{"field": "Points_A", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_pie"}],
      "sort": [{"field": "PIE", "order": "ascending"}]
    },
    {
      "window": [{"op": "rank", "as": "rank_arr"}],
      "sort": [{"field": "ARR", "order": "ascending"}]
    },
    {
      "joinaggregate": [{"op": "count", "as": "total_players"}]
    },
    {
      "calculate": "(datum.rank_mins - 1) / (datum.total_players - 1)",
      "as": "Mins/G"
    },
    {
      "calculate": "(datum.rank_pts - 1) / (datum.total_players - 1)",
      "as": "Pts/G"
    },
    {
      "calculate": "(datum.rank_pie - 1) / (datum.total_players - 1)",
      "as": "Impact (PIE)"
    },
    {
      "calculate": "(datum.rank_arr - 1) / (datum.total_players - 1)",
      "as": "Rim Def (ARR)"
    },
    {
      "filter": {"param": "archetype_team_filter"}
    },
    {
      "fold": ["Mins/G", "Pts/G", "Impact (PIE)", "Rim Def (ARR)"],
      "as": ["Metric", "Percentile_Value"]
    }
  ],
  "mark": {
    "type": "line", 
    "opacity": 0.35, 
    "strokeWidth": 2,
    "interpolate": "linear"
  },
  "encoding": {
    "x": {
      "field": "Metric",
      "type": "nominal",
      "title": "Roster Metric Axes",
      "sort": ["Mins/G", "Pts/G", "Impact (PIE)", "Rim Def (ARR)"],
      "axis": {
        "labelAngle": 0, 
        "grid": true,
        "gridColor": "#e2e8f0",
        "domainColor": "#475569",
        "labelFont": "Plus Jakarta Sans",
        "titleFont": "Plus Jakarta Sans",
        "titlePadding": 12
      }
    },
    "y": {
      "field": "Percentile_Value",
      "type": "quantitative",
      "title": "League Percentile Rank (0 to 1.0)",
      "axis": {
        "format": ".0%",
        "grid": true,
        "gridColor": "#e2e8f0",
        "domainColor": "#475569",
        "labelFont": "Plus Jakarta Sans",
        "titleFont": "Plus Jakarta Sans"
      }
    },
    "color": {
      "field": "Team",
      "type": "nominal",
      "title": "Team Squad",
      "scale": {
        "domain": [
          "Adelaide", "Brisbane", "Cairns", "Illawarra", "Melbourne", 
          "New Zealand", "Perth", "South East Melbourne", "Sydney", "Tasmania"
        ],
        "range": [
          "#0f172a", "#1e293b", "#334155", "#475569", 
          "#0ea5e9", "#0284c7", "#0369a1", "#075985",
          "#566573", "#78281f"
        ]
      },
      "legend": {
        "titleFont": "Plus Jakarta Sans",
        "labelFont": "Plus Jakarta Sans",
        "symbolType": "circle"
      }
    },
    "detail": {"field": "Player"}
  },
  "config": {
    "font": "Plus Jakarta Sans",
    "view": {"stroke": "transparent"}
  }
}