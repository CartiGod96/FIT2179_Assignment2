{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Team Period Percentages Heatmap via nbl-team-stats.csv",
  "data": {
    "url": "data/nbl-team-stats.csv"
  },
  "transform": [
    {
      "fold": ["Period1_Percentage", "Period2_Percentage", "Period3_Percentage", "Period4_Percentage"],
      "as": ["Period_Raw", "Efficiency"]
    },
    {
      "calculate": "datum.Period_Raw == 'Period1_Percentage' ? 'Q1' : datum.Period_Raw == 'Period2_Percentage' ? 'Q2' : datum.Period_Raw == 'Period3_Percentage' ? 'Q3' : 'Q4'",
      "as": "Quarter"
    }
  ],
  "width": 780,
  "height": 300,
  "mark": {"type": "rect", "stroke": "#ffffff", "strokeWidth": 1.5},
  "encoding": {
    "x": {
      "field": "Quarter",
      "type": "ordinal",
      "title": "Game Period",
      "sort": ["Q1", "Q2", "Q3", "Q4"],
      "axis": {"labelAngle": 0, "grid": false}
    },
    "y": {
      "field": "Team",
      "type": "nominal",
      "title": "Franchise",
      "axis": {"grid": false}
    },
    "color": {
      "field": "Efficiency",
      "type": "quantitative",
      "title": "Eff % Index",
      "scale": {
        "type": "linear",
        "domain": [80, 100, 115],
        "range": ["#d7191c", "#f7f7f7", "#2c7bb6"]
      }
    },
    "tooltip": [
      {"field": "Team", "type": "nominal"},
      {"field": "Quarter", "type": "nominal", "title": "Quarter"},
      {"field": "Efficiency", "type": "quantitative", "title": "Efficiency Index", "format": ".1f"}
    ]
  }
}