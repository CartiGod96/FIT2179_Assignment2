{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Team Period Percentages Heatmap via nbl-team-stats.csv",
  "data": { "url": "data/nbl-team-stats.csv" },
  "transform": [
    {
      "fold": ["Period1_Percentage", "Period2_Percentage", "Period3_Percentage", "Period4_Percentage"],
      "as": ["Period_Raw", "Efficiency"]
    },
    {
      "calculate": "datum.Period_Raw == 'Period1_Percentage' ? 'Q1' : datum.Period_Raw == 'Period2_Percentage' ? 'Q2' : datum.Period_Raw == 'Period3_Percentage' ? 'Q3' : 'Q4'",
      "as": "Quarter"
    }
  ],
  "width": "container",
  "height": 320,
  "params": [
    {
      "name": "cell_hover",
      "select": {"type": "point", "on": "mouseover", "clear": "mouseout", "nearest": false}
    }
  ],
  "mark": {"type": "rect", "strokeWidth": 1.5},
  "encoding": {
    "x": {
      "field": "Quarter",
      "type": "ordinal",
      "title": "Game Period",
      "sort": ["Q1", "Q2", "Q3", "Q4"],
      "axis": {"labelAngle": 0, "grid": false, "labelFontWeight": "bold"}
    },
    "y": {
      "field": "Team",
      "type": "nominal",
      "title": null,
      "axis": {"grid": false, "labelFontWeight": "bold", "labelFontSize": 11}
    },
    "color": {
      "field": "Efficiency",
      "type": "quantitative",
      "title": "Eff % Index",
      "scale": {
        "type": "linear",
        "domain": [85, 100, 115],
        "range": ["#f43f5e", "#f1f5f9", "#0ea5e9"],
        "interpolate": "hcl",
        "clamp": true
      },
      "legend": {"orient": "right", "titleFontWeight": "bold"}
    },
    "stroke": {
      "condition": {"param": "cell_hover", "value": "#0f172a"},
      "value": "#ffffff"
    },
    "tooltip": [
      {"field": "Team", "type": "nominal"},
      {"field": "Quarter", "type": "nominal", "title": "Quarter"},
      {"field": "Efficiency", "type": "quantitative", "title": "Efficiency Index", "format": ".1f"}
    ]
  }
}