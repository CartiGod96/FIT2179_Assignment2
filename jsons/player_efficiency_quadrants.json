{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Advanced Defensive Performance and Rim Protection Quadrants (Chart 10)",
  "width": "container",
  "height": 350,
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "params": [
    {
      "name": "qd_filter_minutes_slider",
      "value": 10,
      "bind": {
        "input": "range",
        "min": 1,
        "max": 35,
        "step": 1,
        "name": "Minimum Minutes Played per Game: "
      }
    }
  ],
  "transform": [
    {"filter": "datum.Minutes_A >= qd_filter_minutes_slider"},
    {"filter": "datum.ARR > 0"}
  ],
  "layer": [
    {
      "name": "scatter_layer",
      "params": [
        {
          "name": "qd_legend_toggle_axis",
          "select": {"type": "point", "fields": ["Team"]},
          "bind": "legend"
        },
        {
          "name": "qd_hover_interactive_node",
          "select": {"type": "point", "on": "mouseover", "clear": "mouseout"}
        }
      ],
      "mark": {"type": "circle", "cursor": "pointer"},
      "encoding": {
        "x": {
          "field": "ARR",
          "type": "quantitative",
          "title": "Advanced Rim Recovery / Position Index (ARR)",
          "scale": {"domain": [0, 4]}
        },
        "y": {
          "field": "Blocks_A",
          "type": "quantitative",
          "title": "Blocks per Game",
          "scale": {"domain": [0, 2.5]}
        },
        "size": {
          "condition": {"param": "qd_hover_interactive_node", "value": 340},
          "field": "Matches",
          "type": "quantitative",
          "title": "Games Played",
          "scale": {"range": [40, 240]}
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"}
        },
        "stroke": {
          "condition": {"param": "qd_hover_interactive_node", "value": "#0f172a"},
          "value": "transparent"
        },
        "strokeWidth": {
          "condition": {"param": "qd_hover_interactive_node", "value": 2},
          "value": 0
        },
        "opacity": {
          "condition": [
            {"param": "qd_hover_interactive_node", "value": 1.0},
            {"param": "qd_legend_toggle_axis", "value": 0.75}
          ],
          "value": 0.08
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "Matches", "type": "quantitative", "title": "Matches Played"},
          {"field": "Blocks_A", "type": "quantitative", "title": "Blocks/Game"},
          {"field": "ARR", "type": "quantitative", "title": "ARR Rating"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"y": {"datum": 0.4}}
    },
    {
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"x": {"datum": 1.5}}
    }
  ]
}