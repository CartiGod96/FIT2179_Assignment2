{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Defensive Disruptors and Playmaking Stock Quadrants (Chart 10)",
  "width": "container",
  "height": 350,
  "data": {
    "url": "data/nbl-player-stats.csv",
    "format": {
      "type": "csv",
      "parse": {
        "Minutes_A": "number",
        "Blocks_A": "number",
        "Steals_A": "number",
        "Matches": "number"
      }
    }
  },
  "params": [
    {
      "name": "qd_filter_minutes_slider",
      "value": 10,
      "bind": {
        "input": "range",
        "min": 1,
        "max": 35,
        "step": 1,
        "name": "Minimum Minutes Played per Game: "
      }
    }
  ],
  "transform": [
    {"filter": "datum.Minutes_A >= qd_filter_minutes_slider"},
    {"filter": "datum.Steals_A >= 0"},
    {"filter": "datum.Blocks_A >= 0"}
  ],
  "layer": [
    {
      "description": "Vertical baseline quadrant divider (League Mean Steals)",
      "mark": {
        "type": "rule",
        "color": "#64748b",
        "strokeDash": [4, 4],
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "aggregate": "mean",
          "field": "Steals_A",
          "type": "quantitative"
        }
      }
    },
    {
      "description": "Horizontal baseline quadrant divider (League Mean Blocks)",
      "mark": {
        "type": "rule",
        "color": "#64748b",
        "strokeDash": [4, 4],
        "strokeWidth": 1.5
      },
      "encoding": {
        "y": {
          "aggregate": "mean",
          "field": "Blocks_A",
          "type": "quantitative"
        }
      }
    },
    {
      "params": [
        {
          "name": "qd_legend_toggle_axis",
          "select": {"type": "point", "fields": ["Team"]},
          "bind": "legend"
        },
        {
          "name": "qd_hover_interactive_node",
          "select": {"type": "point", "on": "mouseover", "clear": "mouseout", "empty": "none"}
        }
      ],
      "mark": {"type": "circle", "cursor": "pointer"},
      "encoding": {
        "x": {
          "field": "Steals_A",
          "type": "quantitative",
          "title": "Steals per Game",
          "scale": {"domain": [0, 2.5]}
        },
        "y": {
          "field": "Blocks_A",
          "type": "quantitative",
          "title": "Blocks per Game",
          "scale": {"domain": [0, 2.5]}
        },
        "size": {
          "condition": {"param": "qd_hover_interactive_node", "value": 340},
          "field": "Matches",
          "type": "quantitative",
          "title": "Games Played",
          "scale": {
            "zero": false,
            "range": [40, 240]
          }
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"}
        },
        "stroke": {
          "condition": {"param": "qd_hover_interactive_node", "value": "#0f172a"},
          "value": "transparent"
        },
        "strokeWidth": {
          "condition": {"param": "qd_hover_interactive_node", "value": 2},
          "value": 0
        },
        "opacity": {
          "condition": [
            {"param": "qd_hover_interactive_node", "value": 1.0},
            {"param": "qd_legend_toggle_axis", "value": 0.75}
          ],
          "value": 0.08
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "Matches", "type": "quantitative", "title": "Matches Played"},
          {"field": "Steals_A", "type": "quantitative", "title": "Steals/Game"},
          {"field": "Blocks_A", "type": "quantitative", "title": "Blocks/Game"}
        ]
      }
    }
  ]
}