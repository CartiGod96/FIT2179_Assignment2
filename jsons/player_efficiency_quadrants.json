{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Advanced Player Performance Quadrants",
  "width": 500,
  "height": 380,
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {
      "calculate": "datum.Points / (2 * (datum.FieldGoalsAttempted + 0.44 * datum.FreeThrowsAttempted))",
      "as": "TrueShootingPercentage"
    },
    {
      "calculate": "datum.Assists / max(datum.Turnovers, 1)",
      "as": "AssistToTurnoverRatio"
    },
    {"filter": "datum.MinutesPlayed > 100"}
  ],
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.6, "size": 60},
      "encoding": {
        "x": {
          "field": "AssistToTurnoverRatio",
          "type": "quantitative",
          "title": "Playmaking Security (Assists / Turnovers)",
          "scale": {"domain": [0, 4]}
        },
        "y": {
          "field": "TrueShootingPercentage",
          "type": "quantitative",
          "title": "True Shooting Percentage (TS%)",
          "axis": {"format": "%"},
          "scale": {"domain": [0.3, 0.7]}
        },
        "color": {"field": "Position", "type": "nominal", "scale": {"scheme": "dark2"}},
        "tooltip": [
          {"field": "PlayerName", "type": "nominal", "title": "Player"},
          {"field": "Team", "type": "nominal"},
          {"field": "TrueShootingPercentage", "type": "quantitative", "title": "TS%", "format": ".1%"},
          {"field": "AssistToTurnoverRatio", "type": "quantitative", "title": "AST/TO Ratio", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"y": {"datum": 0.52}}
    },
    {
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"x": {"datum": 1.5}}
    }
  ]
}