{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Advanced Defensive Performance and Rim Protection Quadrants (Chart 10)",
  "width": 500,
  "height": 350,
  "autosize": "fit",
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {"filter": "datum.Minutes_A > 10"},
    {"filter": "datum.ARR > 0"}
  ],
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.6, "size": 75},
      "encoding": {
        "x": {
          "field": "ARR",
          "type": "quantitative",
          "title": "Advanced Rim Recovery / Position Index (ARR)",
          "scale": {"domain": [0, 4]}
        },
        "y": {
          "field": "Blocks_A",
          "type": "quantitative",
          "title": "Blocks per Game",
          "scale": {"domain": [0, 2.5]}
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": {"columns": 2, "orient": "right", "title": "Franchise"}
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "Blocks_A", "type": "quantitative", "title": "Blocks per Game"},
          {"field": "ARR", "type": "quantitative", "title": "ARR Rating"}
        ]
      }
    },
    {
      "comment": "Median League Baseline for Blocks",
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"y": {"datum": 0.4}}
    },
    {
      "comment": "Adjusted Median Baseline for ARR to cut cleanly through the true data domain",
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"x": {"datum": 1.5}}
    }
  ]
}