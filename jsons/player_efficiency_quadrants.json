{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Advanced Player Performance Quadrants (Chart 10)",
  "width": 500,
  "height": 380,
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {
      "calculate": "datum.Assists_A / max(datum.Turnovers_A, 0.5)",
      "as": "AssistToTurnoverRatio"
    },
    {"filter": "datum.Minutes_A > 10"}
  ],
  "layer": [
    {
      "mark": {"type": "circle", "opacity": 0.6, "size": 70},
      "encoding": {
        "x": {
          "field": "AssistToTurnoverRatio",
          "type": "quantitative",
          "title": "Playmaking Security (Assists / Turnovers Ratio)",
          "scale": {"domain": [0, 4]}
        },
        "y": {
          "field": "ThreePointPercentage",
          "type": "quantitative",
          "title": "Three-Point Shooting Accuracy",
          "scale": {"domain": [0, 0.6]},
          "axis": {"format": "%"}
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"}
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "ThreePointPercentage", "type": "quantitative", "title": "3PT %", "format": ".1%"},
          {"field": "AssistToTurnoverRatio", "type": "quantitative", "title": "AST/TO Ratio", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"y": {"datum": 0.35}}
    },
    {
      "mark": {"type": "rule", "color": "#7f8c8d", "strokeDash": [4, 4]},
      "encoding": {"x": {"datum": 1.5}}
    }
  ]
}