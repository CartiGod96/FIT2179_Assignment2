{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "NBL Player Offensive Efficiency Scatter Plot",
  "width": 600,
  "height": 400,
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "params": [
    {
      "name": "TeamSelect",
      "select": {
        "type": "point",
        "fields": ["Team"]
      },
      "bind": {
        "input": "select",
        "options": [
          null,
          "Adelaide 36ers",
          "Brisbane Bullets",
          "Cairns Taipans",
          "Illawarra Hawks",
          "Melbourne United",
          "New Zealand Breakers",
          "Perth Wildcats",
          "South East Melbourne Phoenix",
          "Sydney Kings",
          "Tasmania JackJumpers"
        ],
        "labels": [
          "Show All Teams",
          "Adelaide 36ers",
          "Brisbane Bullets",
          "Cairns Taipans",
          "Illawarra Hawks",
          "Melbourne United",
          "New Zealand Breakers",
          "Perth Wildcats",
          "South East Melbourne Phoenix",
          "Sydney Kings",
          "Tasmania JackJumpers"
        ],
        "name": "Filter Franchise: "
      }
    }
  ],
  "transform": [
    {
      "filter": {"param": "TeamSelect"}
    }
  ],
  "mark": {
    "type": "circle",
    "size": 100,
    "opacity": 0.75,
    "cursor": "pointer"
  },
  "encoding": {
    "x": {
      "field": "Assists_A",
      "type": "quantitative",
      "title": "Average Assists per Game (AST)",
      "axis": {"grid": true}
    },
    "y": {
      "field": "Points_A",
      "type": "quantitative",
      "title": "Average Points Scored per Game (PTS)",
      "axis": {"grid": true}
    },
    "color": {
      "field": "Team",
      "type": "nominal",
      "title": "Team",
      "scale": {"scheme": "tableau10"}
    },
    "tooltip": [
      {"field": "Player", "type": "nominal", "title": "Player"},
      {"field": "Team", "type": "nominal", "title": "Team"},
      {"field": "Points_A", "type": "quantitative", "title": "Points/Game"},
      {"field": "Assists_A", "type": "quantitative", "title": "Assists/Game"},
      {"field": "Minutes_A", "type": "quantitative", "title": "Mins/Game", "format": ".1f"}
    ]
  }
}