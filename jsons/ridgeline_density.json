{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Ridgeline Plot of Supercoach Production Rate - With Tooltips",
  "data": {"url": "data/nbl-player-stats.csv"},
  "facet": {
    "row": {
      "field": "Team",
      "type": "nominal",
      "header": {
        "title": null,
        "labelAlign": "right",
        "labelAngle": 0,
        "labelFontWeight": "bold",
        "labelPadding": 12,
        "labelFontSize": 11
      }
    }
  },
  "spacing": -26,
  "spec": {
    "width": 580,
    "height": 45,
    "autosize": {
      "type": "fit-x",
      "contains": "padding"
    },
    "params": [
      {
        "name": "row_hover",
        "select": {"type": "point", "on": "mouseover", "clear": "mouseout", "fields": ["Team"]}
      }
    ],
    "transform": [
      {"filter": "datum.Minutes_A >= 10"},
      {
        "density": "Supercoach_40",
        "groupby": ["Team"],
        "extent": [0, 70],
        "steps": 100
      }
    ],
    "mark": {
      "type": "area",
      "interpolate": "monotone",
      "stroke": "#0f172a",
      "strokeWidth": 1.5
    },
    "encoding": {
      "x": {
        "field": "value",
        "type": "quantitative",
        "title": "Supercoach Production Pace (Per 40 Mins)",
        "axis": {"grid": false}
      },
      "y": {
        "field": "density",
        "type": "quantitative",
        "axis": null,
        "scale": {"range": [45, -20]}
      },
      "fill": {
        "condition": {"param": "row_hover", "value": "#0ea5e9"},
        "value": "#94a3b8"
      },
      "fillOpacity": {
        "condition": {"param": "row_hover", "value": 0.85},
        "value": 0.3
      },
      "tooltip": [
        {"field": "Team", "type": "nominal"},
        {"field": "value", "type": "quantitative", "title": "Supercoach Pace", "format": ".1f"}
      ]
    }
  },
  "config": {
    "view": {"stroke": null}
  }
}