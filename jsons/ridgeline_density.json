{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Ridgeline Plot of Supercoach Production Rate",
  "data": {"url": "nbl-player-stats.csv"},
  "width": 700,
  "height": 50,
  "transform": [
    {"filter": "datum.Minutes_A >= 10"},
    {
      "density": "Supercoach_40",
      "groupby": ["Team"],
      "extent": [0, 150],
      "steps": 100
    }
  ],
  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "fill": "skyblue",
    "stroke": "black",
    "strokeWidth": 1,
    "fillOpacity": 0.7
  },
  "encoding": {
    "x": {
      "field": "value",
      "type": "quantitative",
      "title": "Supercoach Production Pace (Per 40 Mins)",
      "axis": {"grid": false}
    },
    "y": {
      "field": "density",
      "type": "quantitative",
      "axis": null,
      "scale": {"range": [50, -20]}
    },
    "row": {
      "field": "Team",
      "type": "nominal",
      "header": {
        "title": null,
        "labelAlign": "right",
        "labelAngle": 0,
        "labelFontWeight": "bold",
        "labelPadding": 10
      },
      "spacing": -25
    }
  },
  "config": {
    "view": {"stroke": null}
  }
}