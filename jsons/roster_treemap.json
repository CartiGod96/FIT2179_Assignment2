{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 800,
  "height": 450,
  "data": [
    {
      "name": "raw",
      "url": "nbl-player-stats.csv", 
      "format": {"type": "csv", "parse": "auto"},
      "transform": [
        {
          "type": "formula",
          "as": "ScoringImpact",
          "expr": "datum.Points_A + (datum.ThreePointersMade_A * 2) + (datum.PointsInThePaint_A * 0.5)"
        },
        {"type": "filter", "expr": "datum.ScoringImpact > 0"}
      ]
    },
    {
      "name": "tree",
      "source": "raw",
      "transform": [
        {"type": "nest", "keys": ["Team"]},
        {
          "type": "treemap",
          "field": "ScoringImpact",
          "round": true,
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}]
        }
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [{"type": "filter", "expr": "!datum.children"}]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "raw", "field": "Team"},
      "range": {"scheme": "category20"}
    }
  ],
  "marks": [
    {
      "type": "rect",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {"stroke": {"value": "#ffffff"}},
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "Team"},
          "tooltip": {"signal": "datum.Player + ': ' + format(datum.ScoringImpact, '.1f')"}
        }
      }
    }
  ]
}