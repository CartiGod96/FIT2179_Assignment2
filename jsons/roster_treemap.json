{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "nbl-player-stats.csv"},
  "transform": [
    {
      "calculate": "datum.Points_A + (datum.ThreePointersMade_A * 2) + (datum.PointsInThePaint_A * 0.5)",
      "as": "ScoringImpact"
    },
    {"filter": "datum.ScoringImpact > 0"}
  ],
  "mark": {"type": "rect", "stroke": "white"},
  "encoding": {
    "color": {"field": "Team", "type": "nominal", "scale": {"scheme": "category20"}},
    "tooltip": [
      {"field": "Player", "type": "nominal"},
      {"field": "ScoringImpact", "type": "quantitative", "format": ".1f"}
    ],
    "x": {"field": "x0", "type": "quantitative", "axis": null},
    "y": {"field": "y0", "type": "quantitative", "axis": null},
    "x2": {"field": "x2", "type": "quantitative"},
    "y2": {"field": "y2", "type": "quantitative"}
  },
  "width": 800,
  "height": 450,
  "mark": "treemap"
}