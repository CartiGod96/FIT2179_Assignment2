{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 510,
  "height": 330,
  "padding": 10,
  "data": [
    {
      "name": "raw",
      "url": "data/nbl-player-stats.csv",
      "format": {"type": "csv", "parse": "auto"},
      "transform": [
        {
          "type": "formula",
          "as": "ScoringImpact",
          "expr": "datum.Points_A + (datum.ThreePointersMade_A * 2) + (datum.PointsInThePaint_A * 0.5)"
        },
        {"type": "filter", "expr": "datum.ScoringImpact > 0"}
      ]
    },
    {
      "name": "tree",
      "source": "raw",
      "transform": [
        {"type": "nest", "keys": ["Team"]},
        {
          "type": "treemap",
          "field": "ScoringImpact",
          "round": true,
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}]
        }
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [
        {"type": "filter", "expr": "!datum.children"}
      ]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": {"data": "raw", "field": "Team"},
      "range": {"scheme": "category20"}
    }
  ],
  "legends": [
    {
      "fill": "color",
      "title": "Franchise Squad",
      "orient": "right",
      "titleFont": "Plus Jakarta Sans",
      "labelFont": "Plus Jakarta Sans",
      "encode": {
        "symbols": {
          "update": {
            "shape": {"value": "circle"},
            "size": {"value": 80}
          }
        }
      }
    }
  ],
  "marks": [
    {
      "type": "rect",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {
          "stroke": {"value": "#ffffff"},
          "strokeWidth": {"value": 1.5}
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "Team"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "leaves"},
      "interactive": false,
      "encode": {
        "enter": {
          "font": {"value": "Plus Jakarta Sans"},
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "fill": {"value": "#ffffff"},
          "fontSize": {"value": 9},
          "text": {"field": "Player"}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "0.5 * (datum.y0 + datum.y1)"},
          "opacity": {"signal": "datum.x1 - datum.x0 > 40 && datum.y1 - datum.y0 > 20 ? 1 : 0"}
        }
      }
    }
  ]
}