{
  "$schema": "https://vega.github.io/schema/vega/v5.json",
  "width": 800,
  "height": 450,
  "data": [
    {
      "name": "raw",
      "url": "data/nbl-player-stats.csv",
      "format": {"type": "csv", "parse": "auto"},
      "transform": [
        {
          "type": "formula",
          "as": "ScoringImpact",
          "expr": "datum.Points_A + (datum.ThreePointersMade_A * 2) + (datum.PointsInThePaint_A * 0.5)"
        },
        {"type": "filter", "expr": "datum.ScoringImpact > 0"}
      ]
    },
    {
      "name": "tree",
      "source": "raw",
      "transform": [
        {"type": "nest", "keys": ["Team"]},
        {
          "type": "treemap",
          "field": "ScoringImpact",
          "round": true,
          "method": "squarify",
          "size": [{"signal": "width"}, {"signal": "height"}]
        }
      ]
    },
    {
      "name": "leaves",
      "source": "tree",
      "transform": [{"type": "filter", "expr": "!datum.children"}]
    }
  ],
  "scales": [
    {
      "name": "color",
      "type": "ordinal",
      "domain": [
        "Adelaide", "Brisbane", "Cairns", "Illawarra", "Melbourne", 
        "New Zealand", "Perth", "South East Melbourne", "Sydney", "Tasmania"
      ],
      "range": [
        "#0f172a", "#1e293b", "#334155", "#475569", 
        "#0ea5e9", "#0284c7", "#0369a1", "#075985",
        "#566573", "#78281f"
      ]
    }
  ],
  "marks": [
    {
      "type": "rect",
      "from": {"data": "leaves"},
      "encode": {
        "enter": {
          "stroke": {"value": "#ffffff"},
          "strokeWidth": {"value": 1.5}
        },
        "update": {
          "x": {"field": "x0"},
          "y": {"field": "y0"},
          "x2": {"field": "x1"},
          "y2": {"field": "y1"},
          "fill": {"scale": "color", "field": "Team"}
        }
      }
    },
    {
      "type": "text",
      "from": {"data": "leaves"},
      "interactive": false,
      "encode": {
        "enter": {
          "font": {"value": "Plus Jakarta Sans"},
          "fontWeight": {"value": "600"},
          "fontSize": {"value": 11},
          "fill": {"value": "#ffffff"},
          "align": {"value": "center"},
          "baseline": {"value": "middle"},
          "text": {"field": "Player"}
        },
        "update": {
          "x": {"signal": "0.5 * (datum.x0 + datum.x1)"},
          "y": {"signal": "0.5 * (datum.y0 + datum.y1)"}
        }
      }
    }
  ]
}