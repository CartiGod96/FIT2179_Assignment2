{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "data/nbl-player-stats.csv"},
  "transform": [
    {
      "calculate": "datum.Points_A + (datum.ThreePointersMade_A * 2) + (datum.PointsInThePaint_A * 0.5)",
      "as": "ScoringImpact"
    },
    {"filter": "datum.ScoringImpact > 0"},
    {
      "nest": [{"field": "Team"}, {"field": "Player"}]
    },
    {
      "treemap": "ScoringImpact",
      "method": "squarify"
    }
  ],
  "width": 800,
  "height": 450,
  "mark": {"type": "rect", "stroke": "white"},
  "encoding": {
    "x": {"field": "x0", "type": "quantitative", "axis": null},
    "y": {"field": "y0", "type": "quantitative", "axis": null},
    "x2": {"field": "x1", "type": "quantitative"},
    "y2": {"field": "y1", "type": "quantitative"},
    "color": {
      "field": "Team", 
      "type": "nominal", 
      "scale": {"scheme": "category20"},
      "legend": null
    },
    "tooltip": [
      {"field": "Player", "type": "nominal"},
      {"field": "ScoringImpact", "type": "quantitative", "format": ".1f"}
    ]
  }
}