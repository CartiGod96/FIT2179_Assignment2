{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Spatial Shot Footprint on a Horizontal Basketball Court Layout.",
  "width": "container",
  "height": 430,
  "layer": [
    {
      "data": { "values": [{}] },
      "mark": { "type": "image", "url": "images/fiba_court_flat.png", "width": 800, "height": 430 },
      "encoding": {
        "x": {"datum": 50, "scale": {"domain": [0, 100]}, "axis": null},
        "y": {"datum": 50, "scale": {"domain": [0, 100]}, "axis": null}
      }
    },
    {
      "data": { "url": "data/nbl_shot_coordinates.csv" },
      "params": [
        {
          "name": "shot_chart_exclusive_dropdown_signal",
          "select": { "type": "point", "fields": ["Team"] },
          "bind": {
            "input": "select",
            "options": [
              null, "Adelaide 36ers", "Brisbane Bullets", "Cairns Taipans", "Illawarra Hawks",
              "Melbourne United", "New Zealand Breakers", "Perth Wildcats",
              "South East Melbourne Phoenix", "Sydney Kings", "Tasmania JackJumpers"
            ],
            "labels": [
              "League-Wide Footprint (Show All)", "Adelaide 36ers", "Brisbane Bullets", "Cairns Taipans", "Illawarra Hawks",
              "Melbourne United", "New Zealand Breakers", "Perth Wildcats",
              "South East Melbourne Phoenix", "Sydney Kings", "Tasmania JackJumpers"
            ],
            "name": "Isolate Team Profile: "
          }
        }
      ],
      "transform": [ { "filter": {"param": "shot_chart_exclusive_dropdown_signal"} } ],
      "mark": { "type": "circle", "size": 16, "cursor": "pointer" },
      "encoding": {
        "x": { "field": "X", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null },
        "y": { "field": "Y", "type": "quantitative", "scale": {"domain": [0, 100]}, "axis": null },
        "color": {
          "field": "Shot_Outcome",
          "type": "nominal",
          "title": "Shot Outcome",
          "scale": { "domain": ["Make", "Miss"], "range": ["#0ea5e9", "#cbd5e1"] }
        },
        "opacity": {
          "value": 0.6
        },
        "tooltip": [
          {"field": "Team", "type": "nominal"},
          {"field": "Shot_Type", "type": "nominal", "title": "Value Class"},
          {"field": "Shot_Outcome", "type": "nominal", "title": "Result"}
        ]
      }
    }
  ]
}