{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Ranked Team Effective Field Goal Percentage Bar Chart with Global Benchmark Line.",
  "width": "container",
  "height": 380,
  "data": { "url": "data/nbl-team-stats.csv" },
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 4, "color": "#2980b9", "height": 20 },
      "encoding": {
        "x": { "field": "EffectiveFieldGoalPercentage", "type": "quantitative", "title": "Effective Field Goal % (eFG%)", "scale": {"domain": [0, 0.65]}, "axis": {"format": "%", "grid": true} },
        "y": { "field": "Team", "type": "nominal", "title": null, "sort": "-x", "axis": { "labelFontSize": 11, "tickSize": 0, "domain": false } },
        "tooltip": [
          {"field": "Team", "type": "nominal"},
          {"field": "EffectiveFieldGoalPercentage", "type": "quantitative", "title": "Team eFG%", "format": ".1%"}
        ]
      }
    },
    {
      "mark": { "type": "rule", "color": "#e74c3c", "strokeWidth": 2, "strokeDash": [4, 4] },
      "encoding": {
        "x": { "aggregate": "mean", "field": "EffectiveFieldGoalPercentage", "type": "quantitative" },
        "y": null
      }
    }
  ]
}