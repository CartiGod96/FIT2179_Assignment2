{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Ranked Team Effective Field Goal Percentage Bar Chart with Benchmark Line.",
  "width": 600,
  "height": 380,
  "data": {
    "url": "data/nbl-team-stats.csv"
  },
  "layer": [
    {
      "comment": "Layer 1: Real-world team performance bars",
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 4,
        "color": "#2980b9"
      },
      "encoding": {
        "x": {
          "field": "EffectiveFieldGoalPercentage",
          "type": "quantitative",
          "title": "Effective Field Goal % (eFG%)",
          "scale": {"domain": [0.4, 0.6]},
          "axis": {"format": "%"}
        },
        "y": {
          "field": "Team",
          "type": "nominal",
          "title": "Franchise",
          "sort": "-x",
          "axis": {"grid": false}
        },
        "tooltip": [
          {"field": "Team", "type": "nominal"},
          {"field": "EffectiveFieldGoalPercentage", "type": "quantitative", "title": "Team eFG%", "format": ".1%"},
          {"field": "EffectiveFieldGoalPercentage_Against", "type": "quantitative", "title": "Opponent eFG%", "format": ".1%"}
        ]
      }
    },
    {
      "comment": "Layer 2: Calculated League Average Reference Line",
      "mark": {
        "type": "rule",
        "color": "#e74c3c",
        "strokeWidth": 2,
        "strokeDash": [4, 4]
      },
      "encoding": {
        "x": {
          "aggregate": "mean",
          "field": "EffectiveFieldGoalPercentage",
          "type": "quantitative"
        }
      }
    }
  ]
}