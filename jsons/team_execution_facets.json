{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Faceted Player Playmaking and Physical Execution Matrix",
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {"filter": "datum.MinutesPlayed > 100"}
  ],
  "hconcat": [
    {
      "width": 240,
      "height": 360,
      "title": "Transition: Assists vs Turnovers",
      "mark": {"type": "circle", "size": 60, "opacity": 0.6},
      "encoding": {
        "x": {
          "field": "Turnovers",
          "type": "quantitative",
          "title": "Season Turnovers"
        },
        "y": {
          "field": "Assists",
          "type": "quantitative",
          "title": "Season Assists"
        },
        "color": {
          "field": "Position",
          "type": "nominal",
          "scale": {"scheme": "dark2"}
        },
        "tooltip": [
          {"field": "PlayerName", "type": "nominal", "title": "Player"},
          {"field": "Team", "type": "nominal"},
          {"field": "Assists", "type": "quantitative"},
          {"field": "Turnovers", "type": "quantitative"}
        ]
      }
    },
    {
      "width": 240,
      "height": 360,
      "title": "Interior: Rebounding Dominance",
      "mark": {"type": "circle", "size": 60, "opacity": 0.6},
      "encoding": {
        "x": {
          "field": "OffensiveRebounds",
          "type": "quantitative",
          "title": "Offensive Rebounds"
        },
        "y": {
          "field": "DefensiveRebounds",
          "type": "quantitative",
          "title": "Defensive Rebounds"
        },
        "color": {
          "field": "Position",
          "type": "nominal",
          "scale": {"scheme": "dark2"}
        },
        "tooltip": [
          {"field": "PlayerName", "type": "nominal", "title": "Player"},
          {"field": "Team", "type": "nominal"},
          {"field": "OffensiveRebounds", "type": "quantitative", "title": "O-Reb"},
          {"field": "DefensiveRebounds", "type": "quantitative", "title": "D-Reb"}
        ]
      }
    }
  ]
}