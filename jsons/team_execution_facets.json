{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Faceted Player Total Floor Impact and Impact Estimate Matrix (Charts 7 & 8)",
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {"filter": "datum.Minutes_A > 10"},
    {"filter": "datum.FIC > 0"},
    {"filter": "datum.PIE > 0"},
    {
      "calculate": "datum.EffectiveFieldGoalPercentage / 100",
      "as": "eFG_Decimal"
    }
  ],
  "hconcat": [
    {
      "width": 220,
      "height": 340,
      "title": "Floor Value: Minutes vs Total FIC",
      "mark": {"type": "circle", "size": 60, "opacity": 0.6},
      "encoding": {
        "x": {
          "field": "Minutes_A",
          "type": "quantitative",
          "title": "Minutes per Game"
        },
        "y": {
          "field": "FIC",
          "type": "quantitative",
          "title": "Floor Impact Counter (FIC)"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": null
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "FIC", "type": "quantitative", "title": "FIC Index"},
          {"field": "Minutes_A", "type": "quantitative", "title": "Minutes/G"}
        ]
      }
    },
    {
      "width": 220,
      "height": 340,
      "title": "Game Swing: True Shot % vs Player Impact",
      "mark": {"type": "circle", "size": 60, "opacity": 0.6},
      "encoding": {
        "x": {
          "field": "eFG_Decimal",
          "type": "quantitative",
          "title": "Effective Field Goal % (eFG%)",
          "axis": {"format": "%"},
          "scale": {"domain": [0.3, 0.7]}
        },
        "y": {
          "field": "PIE",
          "type": "quantitative",
          "title": "Player Impact Estimate (PIE)"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Franchise",
          "scale": {"scheme": "tableau10"}
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "EffectiveFieldGoalPercentage", "type": "quantitative", "title": "eFG% Original"},
          {"field": "PIE", "type": "quantitative", "title": "PIE Rating"}
        ]
      }
    }
  ]
}