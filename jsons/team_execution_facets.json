{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Faceted Player Total Floor Impact and Impact Estimate Matrix with Cross-Highlighting.",
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {"filter": "datum.Minutes_A > 5"},
    {"filter": "datum.FIC > 0"},
    {"filter": "datum.PIE > 0"}
  ],
  "params": [
    {
      "name": "brush_selection",
      "select": {
        "type": "interval",
        "resolve": "global"
      }
    },
    {
      "name": "legend_filter",
      "select": {
        "type": "point", 
        "fields": ["Team"]
      },
      "bind": "legend"
    }
  ],
  "hconcat": [
    {
      "width": 350,
      "height": 340,
      "title": "Floor Value: Minutes vs Total FIC",
      "mark": {"type": "circle", "size": 75},
      "encoding": {
        "x": {
          "field": "Minutes_A",
          "type": "quantitative",
          "title": "Minutes per Game",
          "scale": {"domain": [5, 40]}
        },
        "y": {
          "field": "FIC",
          "type": "quantitative",
          "title": "Floor Impact Counter (FIC)"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": null
        },
        "opacity": {
          "condition": [
            {
              "test": {"and": ["brush_selection", "legend_filter"]},
              "value": 0.85
            }
          ],
          "value": 0.15
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "FIC", "type": "quantitative", "title": "FIC Index", "format": ".2f"},
          {"field": "Minutes_A", "type": "quantitative", "title": "Minutes/G", "format": ".1f"}
        ]
      }
    },
    {
      "width": 350,
      "height": 340,
      "title": "Game Swing: True Shot % vs Player Impact",
      "mark": {"type": "circle", "size": 75},
      "encoding": {
        "x": {
          "field": "EffectiveFieldGoalPercentage",
          "type": "quantitative",
          "title": "Effective Field Goal % (eFG%)",
          "axis": {"format": "%"},
          "scale": {"domain": [0.3, 0.75]}
        },
        "y": {
          "field": "PIE",
          "type": "quantitative",
          "title": "Player Impact Estimate (PIE)"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Franchise",
          "scale": {"scheme": "tableau10"}
        },
        "opacity": {
          "condition": [
            {
              "test": {"and": ["brush_selection", "legend_filter"]},
              "value": 0.85
            }
          ],
          "value": 0.15
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "EffectiveFieldGoalPercentage", "type": "quantitative", "title": "eFG%", "format": ".1%"},
          {"field": "PIE", "type": "quantitative", "title": "PIE Rating", "format": ".2f"}
        ]
      }
    }
  ]
}