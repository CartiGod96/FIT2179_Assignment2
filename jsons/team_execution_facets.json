{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Faceted Player Playmaking and Physical Execution Matrix (Charts 7 & 8)",
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "transform": [
    {"filter": "datum.Minutes_A > 10"}
  ],
  "hconcat": [
    {
      "width": 240,
      "height": 360,
      "title": "Transition: Fast Break vs Giveaways",
      "mark": {"type": "circle", "size": 60, "opacity": 0.6},
      "encoding": {
        "x": {
          "field": "Turnovers_A",
          "type": "quantitative",
          "title": "Turnovers per Game"
        },
        "y": {
          "field": "PointsFastBreak_A",
          "type": "quantitative",
          "title": "Fast Break Points per Game"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": null
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "PointsFastBreak_A", "type": "quantitative", "title": "Fast Break PPG"},
          {"field": "Turnovers_A", "type": "quantitative", "title": "Turnovers/Game"}
        ]
      }
    },
    {
      "width": 240,
      "height": 360,
      "title": "Interior: Paint Points vs Second Chances",
      "mark": {"type": "circle", "size": 60, "opacity": 0.6},
      "encoding": {
        "x": {
          "field": "PointsInThePaint_A",
          "type": "quantitative",
          "title": "Paint Points per Game"
        },
        "y": {
          "field": "PointsSecondChance_A",
          "type": "quantitative",
          "title": "2nd Chance Points per Game"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Franchise",
          "scale": {"scheme": "tableau10"}
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "PointsInThePaint_A", "type": "quantitative", "title": "Paint PPG"},
          {"field": "PointsSecondChance_A", "type": "quantitative", "title": "2nd Chance PPG"}
        ]
      }
    }
  ]
}