{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Faceted Player Total Floor Impact, Impact Estimate, and All-Round Versatility Matrix (Charts 7, 8 & 9)",
  "data": {
    "url": "data/nbl-player-stats.csv"
  },
  "spacing": 40,
  "transform": [
    {"filter": "datum.Minutes_A > 5"},
    {"filter": "datum.FIC > 0"},
    {"filter": "datum.PIE > 0"},
    {"filter": "datum.ARR > 0"},
    {
      "calculate": "datum.EffectiveFieldGoalPercentage / 100",
      "as": "eFG_Decimal"
    }
  ],
  "params": [
    {
      "name": "chart_brush",
      "select": {
        "type": "interval",
        "resolve": "global"
      }
    },
    {
      "name": "legend_selection",
      "select": {
        "type": "point",
        "fields": ["Team"]
      },
      "bind": "legend"
    }
  ],
  "hconcat": [
    {
      "width": 220,
      "height": 340,
      "title": "Volume: Minutes vs Total FIC",
      "mark": {"type": "circle", "size": 55},
      "encoding": {
        "x": {
          "field": "Minutes_A",
          "type": "quantitative",
          "title": "Minutes per Game",
          "scale": {"domain": [5, 40]}
        },
        "y": {
          "field": "FIC",
          "type": "quantitative",
          "title": "Floor Impact Counter (FIC)"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": null
        },
        "opacity": {
          "condition": {
            "test": {"and": ["chart_brush", "legend_selection"]},
            "value": 0.75
          },
          "value": 0.12
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "FIC", "type": "quantitative", "title": "FIC Index"},
          {"field": "Minutes_A", "type": "quantitative", "title": "Minutes/G"}
        ]
      }
    },
    {
      "width": 220,
      "height": 340,
      "title": "Game Swing: True Shot % vs Player Impact",
      "mark": {"type": "circle", "size": 55},
      "encoding": {
        "x": {
          "field": "eFG_Decimal",
          "type": "quantitative",
          "title": "Effective Field Goal % (eFG%)",
          "axis": {"format": "%"},
          "scale": {"domain": [0.3, 0.7]}
        },
        "y": {
          "field": "PIE",
          "type": "quantitative",
          "title": "Player Impact Estimate (PIE)"
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "scale": {"scheme": "tableau10"},
          "legend": null
        },
        "opacity": {
          "condition": {
            "test": {"and": ["chart_brush", "legend_selection"]},
            "value": 0.75
          },
          "value": 0.12
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "EffectiveFieldGoalPercentage", "type": "quantitative", "title": "eFG% Original"},
          {"field": "PIE", "type": "quantitative", "title": "PIE Rating"}
        ]
      }
    },
    {
      "width": 220,
      "height": 340,
      "title": "Versatility: Workload vs All-Round Rating",
      "mark": {"type": "circle", "size": 55},
      "encoding": {
        "x": {
          "field": "Minutes_A",
          "type": "quantitative",
          "title": "Minutes per Game",
          "scale": {"domain": [5, 40]}
        },
        "y": {
          "field": "ARR",
          "type": "quantitative",
          "title": "All-Round Rating (Wheelo ARR)",
          "scale": {"zero": false}
        },
        "color": {
          "field": "Team",
          "type": "nominal",
          "title": "Franchise",
          "scale": {"scheme": "tableau10"}
        },
        "opacity": {
          "condition": {
            "test": {"and": ["chart_brush", "legend_selection"]},
            "value": 0.75
          },
          "value": 0.12
        },
        "tooltip": [
          {"field": "Player", "type": "nominal"},
          {"field": "Team", "type": "nominal"},
          {"field": "ARR", "type": "quantitative", "title": "All-Round Rating"},
          {"field": "Minutes_A", "type": "quantitative", "title": "Minutes/G"}
        ]
      }
    }
  ]
}