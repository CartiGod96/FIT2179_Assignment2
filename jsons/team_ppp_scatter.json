{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Team Offensive vs Defensive Points Per Possession Matrix",
  "width": "container",
  "height": 400,
  "data": { "url": "data/nbl-team-stats.csv" },
  "params": [
    {
      "name": "team_ppp_exclusive_hover_signal",
      "select": { "type": "point", "fields": ["Team"], "on": "pointerover" }
    }
  ],
  "mark": { "type": "circle", "size": 180, "cursor": "pointer" },
  "encoding": {
    "x": { "field": "PPP_Against", "type": "quantitative", "title": "Defensive Efficiency (Points Allowed / Possession)", "scale": {"zero": false} },
    "y": { "field": "PPP", "type": "quantitative", "title": "Offensive Efficiency (Points Scored / Possession)", "scale": {"zero": false} },
    "color": { "field": "Team", "type": "nominal", "title": "Franchise", "scale": {"scheme": "tableau10"} },
    "opacity": {
      "condition": { "param": "team_ppp_exclusive_hover_signal", "value": 1, "empty": true },
      "value": 0.2
    },
    "tooltip": [
      {"field": "Team", "type": "nominal"},
      {"field": "PPP", "type": "quantitative", "title": "Offensive PPP", "format": ".2f"},
      {"field": "PPP_Against", "type": "quantitative", "title": "Defensive PPP", "format": ".2f"},
      {"field": "WinPercentage", "type": "quantitative", "title": "Win Rate (%)", "format": ".1f"}
    ]
  }
}